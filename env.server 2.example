# 复制这个文件为 .env，填好后不要提交到 git / 不要截图分享
# 生成随机 token 可以用: openssl rand -hex 16

PROBE_BOT_TOKEN=从 BotFather 拿到的 token
PROBE_CHAT_ID=你自己的 telegram chat_id
PROBE_AUTH_TOKEN=一串随机字符串，agent 上报时也要用同一个值

# 绑定到 WireGuard 网卡的内网 IP(比如 10.0.0.1)，不要用 0.0.0.0 或公网 IP
# 这样端口只在 WireGuard 隧道内可达，公网连不进来(见 README 安全部分)
PROBE_SERVER_HOST=10.0.0.1
PROBE_SERVER_PORT=8000

PROBE_CPU_THRESHOLD=90
PROBE_MEM_THRESHOLD=90
PROBE_OFFLINE_THRESHOLD_SEC=90
PROBE_STALE_REMOVE_DAYS=7
PROBE_CHECK_INTERVAL_SEC=15
PROBE_FORCE_REFRESH_WAIT_SEC=6
