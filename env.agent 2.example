# 复制这个文件为 .env，放在 agent.py 同目录，每台服务器上的值不一样(至少 NODE_ID/NODE_NAME 要不同)

# 服务端的 WireGuard 内网 IP（不是公网 IP），比如 10.0.0.1
PROBE_SERVER_URL=http://10.0.0.1:8000/report
PROBE_AUTH_TOKEN=要和服务端 .env 里的 PROBE_AUTH_TOKEN 完全一致

PROBE_NODE_ID=hk-01
PROBE_NODE_NAME=香港-01
PROBE_REPORT_INTERVAL_SEC=15
PROBE_REFRESH_CHECK_INTERVAL_SEC=3

# 走 WireGuard 隧道，流量已加密，跳过 agent.py 里的强制 https 检查
PROBE_ALLOW_HTTP=1
